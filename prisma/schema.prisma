// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String?  // Admin/Client credentials password
  phone         String?
  role          Role     @default(CLIENT)
  createdAt     DateTime @default(now())
  leads         Lead[]
  searches      Search[]
}

enum Role {
  CLIENT
  ADMIN
}

model Project {
  id                String   @id @default(cuid())
  name              String
  developer         String
  corridor          String   // e.g., "Shadnagar", "Pharma City", "Sangareddy"
  city              String   @default("Hyderabad")
  minBudgetLakhs    Float
  maxBudgetLakhs    Float
  minHorizonYears   Int
  maxHorizonYears   Int
  riskLevel         RiskLevel
  propertyType      String   // Residential, Commercial, Plots, Villa
  infraHighlights   String[] // Array of infra tags
  exitOpportunities String[]
  comparables       String[]
  description       String
  brochureUrl       String?
  imageUrls         String[]
  status            ProjectStatus @default(ACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  leads             Lead[]
  matches           ProjectLeadMatch[]
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ACTIVE
  SOLD_OUT
  UPCOMING
  ARCHIVED
}

model Lead {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  name            String
  email           String
  phone           String
  budget          Float    // in Lakhs
  horizon         Int      // years
  city            String
  notes           String?
  status          LeadStatus @default(NEW)
  source          String   @default("portal") // portal, manual, import
  assignedTo      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  roadmap         LeadRoadmap?
  
  // Advanced Features Additions
  persona            BuyerPersona?
  personaScore       Int?
  personaUpdatedAt   DateTime?
  personaReason      String?
  leadScore          Int?                @default(0)
  leadScoreGrade     ScoreGrade?
  leadScoreUpdatedAt DateTime?
  leadScoreFactors   Json?
  matches            ProjectLeadMatch[]
  whatsAppLogs       WhatsAppLog[]
  emailOptOut        Boolean             @default(false)
  whatsappOptOut     Boolean             @default(false)
  broadcastRecipients BroadcastRecipient[]
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NEGOTIATING
  CONVERTED
  LOST
}

model Search {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  budget     Float
  horizon    Int
  city       String
  aiResponse Json     // Store full AI recommendation response
  createdAt  DateTime @default(now())
}

model LeadRoadmap {
  id              String          @id @default(cuid())
  leadId          String          @unique
  lead            Lead            @relation(fields: [leadId], references: [id])
  targetCloseDate DateTime?
  estimatedValue  Float?      // Deal value in Lakhs
  probability     Int         // 0-100 percentage
  assignedTo      String?
  stages          RoadmapStage[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model RoadmapStage {
  id           String       @id @default(cuid())
  roadmapId    String
  roadmap      LeadRoadmap  @relation(fields: [roadmapId], references: [id])
  stageKey     StageKey
  status       StageStatus  @default(PENDING)
  scheduledAt  DateTime?
  completedAt  DateTime?
  notes        String?
  actionItems  ActionItem[]
  order        Int
}

model ActionItem {
  id           String       @id @default(cuid())
  stageId      String
  stage        RoadmapStage @relation(fields: [stageId], references: [id])
  title        String
  dueDate      DateTime?
  completed    Boolean      @default(false)
  completedAt  DateTime?
}

enum StageKey {
  INITIAL_CONTACT
  NEEDS_ASSESSMENT
  SITE_VISIT
  PROPOSAL_SENT
  NEGOTIATION
  LEGAL_REVIEW
  BOOKING_AMOUNT
  AGREEMENT_SIGNED
  CLOSURE
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum BuyerPersona {
  FIRST_TIME_BUYER
  NRI_INVESTOR
  LAND_SPECULATOR
  RETIREMENT_PLANNER
  HNI_PORTFOLIO_BUILDER
  PROFESSIONAL_FIRST_HOME
}

enum ScoreGrade {
  A
  B
  C
  D
}

enum WATrigger {
  LEAD_CREATED
  STAGE_INITIAL_CONTACT
  STAGE_NEEDS_ASSESSMENT
  SITE_VISIT_REMINDER
  SITE_VISIT_FOLLOWUP
  PROPOSAL_SENT
  NEGOTIATION_START
  STALE_LEAD_7DAYS
  STALE_LEAD_14DAYS
  PROJECT_MATCH_FOUND
  CUSTOM
}

enum WAStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model PersonaConfig {
  id              String       @id @default(cuid())
  persona         BuyerPersona @unique
  displayName     String
  description     String
  minBudgetLakhs  Float?
  maxBudgetLakhs  Float?
  minHorizon      Int?
  maxHorizon      Int?
  riskLevels      RiskLevel[]
  color           String       // hex color for UI badge
  icon            String       // emoji or icon name
  defaultProjects String[]     // project IDs most suitable for this persona
  createdAt       DateTime     @default(now())
}

model ProjectLeadMatch {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id])
  matchScore    Int      // 0-100
  matchReasons  String[] // e.g. ["Budget fits", "Corridor in AI search history"]
  isManualTag   Boolean  @default(false)
  isDismissed   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, leadId])
}

model WhatsAppTemplate {
  id          String          @id @default(cuid())
  name        String          @unique
  trigger     WATrigger
  message     String          // Template with {{merge_tags}}
  isActive    Boolean         @default(true)
  sentCount   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  logs        WhatsAppLog[]
}

model WhatsAppLog {
  id          String          @id @default(cuid())
  leadId      String
  lead        Lead            @relation(fields: [leadId], references: [id])
  templateId  String
  template    WhatsAppTemplate @relation(fields: [templateId], references: [id])
  message     String          // Final message after merge tags filled
  status      WAStatus        @default(PENDING)
  waMessageId String?         // Message ID from WATI
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime        @default(now())
}

model CorridorMetrics {
  id                    String   @id @default(cuid())
  corridor              String   @unique
  city                  String   @default("Hyderabad")
  historicalCAGR        Float    // e.g. 12.5 (percent)
  projectedCAGRMin      Float    // Conservative estimate
  projectedCAGRMax      Float    // Optimistic estimate
  rentalYieldMin        Float    // e.g. 3.5
  rentalYieldMax        Float    // e.g. 5.5
  infraScore            Int      // 1-10 admin-assigned
  demandScore           Int      // 1-10 admin-assigned
  riskLevel             RiskLevel
  lastUpdated           DateTime @updatedAt
  updatedBy             String?
}

model Broadcast {
  id              String          @id @default(cuid())
  name            String          // Admin-given name e.g. "Diwali Offer - NRI Investors"
  channel         BroadcastChannel // WHATSAPP or EMAIL or BOTH
  templateId      String?
  emailSubject    String?
  emailBody       String?
  whatsappMessage String?
  groupType       GroupType       // How the recipients were selected
  groupFilters    Json            // Snapshot of filters used
  recipientCount  Int             @default(0)
  status          BroadcastStatus @default(DRAFT)
  scheduledAt     DateTime?       // null = send immediately
  sentAt          DateTime?
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  recipients      BroadcastRecipient[]
}

model BroadcastRecipient {
  id              String          @id @default(cuid())
  broadcastId     String
  broadcast       Broadcast       @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  leadId          String
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  whatsappStatus  WAStatus?
  emailStatus     EmailStatus?
  whatsappSentAt  DateTime?
  emailSentAt     DateTime?
  emailMessageId  String?
  whatsappMessageId String?
  errorMessage    String?
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  subject     String
  body        String   // HTML email body with {{merge_tags}}
  isActive    Boolean  @default(true)
  sentCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum BroadcastChannel {
  WHATSAPP
  EMAIL
  BOTH
}

enum BroadcastStatus {
  DRAFT
  SENDING
  SENT
  FAILED
  SCHEDULED
}

enum GroupType {
  PERSONA           // All leads of a specific buyer persona
  LEAD_STATUS       // All leads at a specific CRM status
  PIPELINE_STAGE    // All leads at a specific pipeline stage
  SCORE_GRADE       // All leads with a specific score grade (A/B/C/D)
  CORRIDOR_INTEREST // All leads who searched a specific corridor
  BUDGET_RANGE      // All leads within a budget range
  MANUAL_PICK       // Admin hand-picked individual leads
  ALL_LEADS         // Everyone in the database
}

enum EmailStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  FAILED
  BOUNCED
}

// ── GOVERNMENT INFRASTRUCTURE PROJECTS ──────────────────────────────────────

model InfraProject {
  id                String          @id @default(cuid())
  name              String          // "Regional Ring Road - Northern Corridor"
  shortName         String          // "RRR North"
  category          InfraCategory
  subCategory       String?         // "Expressway", "Metro", "SEZ", "Industrial Park"
  description       String
  status            InfraStatus
  completionPct     Int             @default(0)   // 0-100
  estimatedCompletion String?       // "Q3 2027"
  totalInvestmentCr Float?          // Investment in Crores
  expectedJobs      Int?
  affectedCorridors String[]        // corridor names this project impacts
  impactRadius      Float           // km radius of real estate impact
  latitude          Float?
  longitude         Float?
  sourceUrl         String?         // Official government URL
  sourceGO          String?         // Government Order number e.g. "G.O.Ms.No.68"
  tags              String[]        // ["HMDA", "NHAI", "Bharatmala", "TSIIC"]
  approvalAuthority String?         // "HMDA", "DTCP", "NHAI", "TSIIC", "GoT"
  reImpactScore     Int             @default(0)   // 1-10 admin-rated RE impact
  isPublished       Boolean         @default(false)
  milestones        InfraMilestone[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model InfraMilestone {
  id            String       @id @default(cuid())
  projectId     String
  project       InfraProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String       // "Land Acquisition 94% Complete"
  date          DateTime?
  status        MilestoneStatus @default(UPCOMING)
  description   String?
  sourceUrl     String?
}

enum InfraCategory {
  ROAD_HIGHWAY        // RRR, ORR, NH expansions, flyovers
  METRO_RAIL          // Metro extensions, new corridors
  INDUSTRIAL_ZONE     // TSIIC industrial parks, SEZs
  PHARMA_BIOTECH      // Pharma City, Genome Valley
  LOGISTICS_PARK      // Warehousing hubs, dry ports, freight terminals
  AIRPORT_AVIATION    // RGIA expansion, cargo terminals, aerospace SEZ
  GOVT_APPROVAL       // HMDA layout approvals, DTCP approvals
  TOWNSHIP            // Satellite townships, master plan zones
  IT_TECH_PARK        // IT corridors, hardware parks
  UTILITY             // Water supply, power grid, sewage
}

enum InfraStatus {
  ANNOUNCED           // Government announcement only
  APPROVED            // Government order issued
  LAND_ACQUISITION    // Land acquisition in progress
  UNDER_CONSTRUCTION  // Active construction
  PARTIALLY_COMPLETE  // Some phases done
  COMPLETE            // Fully operational
  DELAYED             // Official delay announced
  CANCELLED           // Cancelled or stalled
}

enum MilestoneStatus {
  COMPLETED
  IN_PROGRESS
  UPCOMING
}

// ── AREA APPRECIATION HISTORY ─────────────────────────────────────────────────

model AppreciationHistory {
  id           String   @id @default(cuid())
  corridor     String   // Must match CorridorMetrics.corridor
  year         Int
  quarter      Int?     // 1-4, null = annual
  pricePerSqFt Float    // Average price per sq ft in ₹
  pricePerSqYd Float?   // For plot markets
  yoyChange    Float    // Year-over-year % change
  qoqChange    Float?   // Quarter-over-quarter % change
  sampleSize   Int?     // Number of transactions this is based on
  source       String?  // "RERA Data", "Market Research", "Admin Estimate"
  notes        String?
  createdAt    DateTime @default(now())
}

// ── DEMAND TREND DATA ─────────────────────────────────────────────────────────

model DemandTrend {
  id              String   @id @default(cuid())
  corridor        String
  month           Int      // 1-12
  year            Int
  searchVolume    Int?     // Portal search count for this corridor
  inquiryCount    Int?     // Leads who expressed interest
  siteVisits      Int?     // Site visits arranged
  newListings     Int?     // New projects listed
  inventoryUnits  Int?     // Total units available
  soldUnits       Int?     // Units sold/booked this month
  absorptionRate  Float?   // % of inventory absorbed
  medianDaysOnMkt Int?     // Median days project stays on market
  createdAt       DateTime @default(now())

  @@unique([corridor, month, year])
}

// ── HMDA / DTCP APPROVAL TRACKER ─────────────────────────────────────────────

model ApprovalRecord {
  id              String         @id @default(cuid())
  projectName     String
  developerName   String?
  approvalType    ApprovalType
  authority       ApprovalAuth   // HMDA, DTCP, GHMC, RERA
  approvalNumber  String?        // LP number, RERA number, GO number
  approvalDate    DateTime?
  corridor        String?
  areaAcres       Float?
  surveyNumbers   String[]
  status          ApprovalStatus @default(APPROVED)
  reraNumber      String?
  reraUrl         String?
  notes           String?
  isPublished     Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum ApprovalType {
  LAYOUT_APPROVAL
  BUILDING_PERMISSION
  RERA_REGISTRATION
  ENVIRONMENTAL_CLEARANCE
  SEZ_APPROVAL
  INDUSTRIAL_ALLOTMENT
  TOWNSHIP_APPROVAL
}

enum ApprovalAuth {
  HMDA
  DTCP
  GHMC
  RERA_TELANGANA
  TSIIC
  NHAI
  MOEF     // Ministry of Environment
  GOT      // Government of Telangana
}

enum ApprovalStatus {
  APPROVED
  PENDING
  REVOKED
  EXPIRED
}

// ── CORRIDOR INTELLIGENCE SCORE ───────────────────────────────────────────────

model CorridorIntelligence {
  id                   String   @id @default(cuid())
  corridor             String   @unique
  overallScore         Int      // 1-100 computed
  infraScore           Int      // 1-25: proximity to govt infra projects
  approvalScore        Int      // 1-25: HMDA/DTCP/RERA approvals in zone
  demandScore          Int      // 1-25: search + inquiry trends
  appreciationScore    Int      // 1-25: historical price growth
  investorSentiment    String   // "BULLISH" | "NEUTRAL" | "CAUTIOUS"
  adminNote            String?  // Admin commentary shown to clients
  keyDrivers           String[] // Top 3 reasons for the score
  keyRisks             String[] // Top 2 risks
  bestFor              String[] // Persona types this corridor suits
  lastComputedAt       DateTime @default(now())
}




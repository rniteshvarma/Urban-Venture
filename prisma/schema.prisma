// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String?  // Admin/Client credentials password
  phone         String?
  role          Role     @default(CLIENT)
  createdAt     DateTime @default(now())
  leads         Lead[]
  searches      Search[]
}

enum Role {
  CLIENT
  ADMIN
}

model Project {
  id                String   @id @default(cuid())
  name              String
  developer         String
  corridor          String   // e.g., "Shadnagar", "Pharma City", "Sangareddy"
  city              String   @default("Hyderabad")
  minBudgetLakhs    Float
  maxBudgetLakhs    Float
  minHorizonYears   Int
  maxHorizonYears   Int
  riskLevel         RiskLevel
  propertyType      String   // Residential, Commercial, Plots, Villa
  infraHighlights   String[] // Array of infra tags
  exitOpportunities String[]
  comparables       String[]
  description       String
  brochureUrl       String?
  imageUrls         String[]
  status            ProjectStatus @default(ACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  leads             Lead[]
  matches           ProjectLeadMatch[]
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ACTIVE
  SOLD_OUT
  UPCOMING
  ARCHIVED
}

model Lead {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  name            String
  email           String
  phone           String
  budget          Float    // in Lakhs
  horizon         Int      // years
  city            String
  notes           String?
  status          LeadStatus @default(NEW)
  source          String   @default("portal") // portal, manual, import
  assignedTo      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  roadmap         LeadRoadmap?
  
  // Advanced Features Additions
  persona            BuyerPersona?
  personaScore       Int?
  personaUpdatedAt   DateTime?
  personaReason      String?
  leadScore          Int?                @default(0)
  leadScoreGrade     ScoreGrade?
  leadScoreUpdatedAt DateTime?
  leadScoreFactors   Json?
  matches            ProjectLeadMatch[]
  whatsAppLogs       WhatsAppLog[]
  emailOptOut        Boolean             @default(false)
  whatsappOptOut     Boolean             @default(false)
  broadcastRecipients BroadcastRecipient[]
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NEGOTIATING
  CONVERTED
  LOST
}

model Search {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  budget     Float
  horizon    Int
  city       String
  aiResponse Json     // Store full AI recommendation response
  createdAt  DateTime @default(now())
}

model LeadRoadmap {
  id              String          @id @default(cuid())
  leadId          String          @unique
  lead            Lead            @relation(fields: [leadId], references: [id])
  targetCloseDate DateTime?
  estimatedValue  Float?      // Deal value in Lakhs
  probability     Int         // 0-100 percentage
  assignedTo      String?
  stages          RoadmapStage[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model RoadmapStage {
  id           String       @id @default(cuid())
  roadmapId    String
  roadmap      LeadRoadmap  @relation(fields: [roadmapId], references: [id])
  stageKey     StageKey
  status       StageStatus  @default(PENDING)
  scheduledAt  DateTime?
  completedAt  DateTime?
  notes        String?
  actionItems  ActionItem[]
  order        Int
}

model ActionItem {
  id           String       @id @default(cuid())
  stageId      String
  stage        RoadmapStage @relation(fields: [stageId], references: [id])
  title        String
  dueDate      DateTime?
  completed    Boolean      @default(false)
  completedAt  DateTime?
}

enum StageKey {
  INITIAL_CONTACT
  NEEDS_ASSESSMENT
  SITE_VISIT
  PROPOSAL_SENT
  NEGOTIATION
  LEGAL_REVIEW
  BOOKING_AMOUNT
  AGREEMENT_SIGNED
  CLOSURE
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum BuyerPersona {
  FIRST_TIME_BUYER
  NRI_INVESTOR
  LAND_SPECULATOR
  RETIREMENT_PLANNER
  HNI_PORTFOLIO_BUILDER
  PROFESSIONAL_FIRST_HOME
}

enum ScoreGrade {
  A
  B
  C
  D
}

enum WATrigger {
  LEAD_CREATED
  STAGE_INITIAL_CONTACT
  STAGE_NEEDS_ASSESSMENT
  SITE_VISIT_REMINDER
  SITE_VISIT_FOLLOWUP
  PROPOSAL_SENT
  NEGOTIATION_START
  STALE_LEAD_7DAYS
  STALE_LEAD_14DAYS
  PROJECT_MATCH_FOUND
  CUSTOM
}

enum WAStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model PersonaConfig {
  id              String       @id @default(cuid())
  persona         BuyerPersona @unique
  displayName     String
  description     String
  minBudgetLakhs  Float?
  maxBudgetLakhs  Float?
  minHorizon      Int?
  maxHorizon      Int?
  riskLevels      RiskLevel[]
  color           String       // hex color for UI badge
  icon            String       // emoji or icon name
  defaultProjects String[]     // project IDs most suitable for this persona
  createdAt       DateTime     @default(now())
}

model ProjectLeadMatch {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id])
  matchScore    Int      // 0-100
  matchReasons  String[] // e.g. ["Budget fits", "Corridor in AI search history"]
  isManualTag   Boolean  @default(false)
  isDismissed   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, leadId])
}

model WhatsAppTemplate {
  id          String          @id @default(cuid())
  name        String          @unique
  trigger     WATrigger
  message     String          // Template with {{merge_tags}}
  isActive    Boolean         @default(true)
  sentCount   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  logs        WhatsAppLog[]
}

model WhatsAppLog {
  id          String          @id @default(cuid())
  leadId      String
  lead        Lead            @relation(fields: [leadId], references: [id])
  templateId  String
  template    WhatsAppTemplate @relation(fields: [templateId], references: [id])
  message     String          // Final message after merge tags filled
  status      WAStatus        @default(PENDING)
  waMessageId String?         // Message ID from WATI
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime        @default(now())
}

model CorridorProfile {
  id                    String   @id @default(cuid())
  slug                  String   @unique  // "adibatla", "kadthal-fcda" etc.
  name                  String            // "Adibatla IT & Aerospace Corridor"
  shortName             String            // "Adibatla"
  direction             Direction         // WEST, SOUTH, NORTH, EAST, NORTHWEST, SOUTHEAST
  zone                  String            // "SE Beyond ORR"
  district              String            // "Ranga Reddy", "Sangareddy" etc.
  description           String            // 2-3 sentence description
  heatRating            HeatRating        // FIRE, VERY_HOT, HOT, WARM, EMERGING, EARLY
  investmentCycle       InvCycle          // NOW, MID_CYCLE, WATCH, PATIENT_CAPITAL
  ghmc2025              Boolean           @default(false)  // Included in Dec 2025 GHMC expansion
  hmdaJurisdiction      Boolean           @default(true)
  fcdaZone              Boolean           @default(false)  // Inside FCDA Future City boundary
  rrrAlignment          RRRAlignment?     // NORTH_CORRIDOR, SOUTH_CORRIDOR, BOTH, NONE
  
  // Price data 2026
  plotPriceMinSqYd      Float?
  plotPriceMidSqYd      Float?
  plotPriceMaxSqYd      Float?
  aptPriceMinSqFt       Float?
  aptPriceMaxSqFt       Float?
  
  // Historical prices for chart seeding
  price2020SqYd         Float?
  price2022SqYd         Float?
  price2024SqYd         Float?
  price2026SqYd         Float?
  appreciationSince2020 Float?   // percentage e.g. 125.0
  
  // Investment metrics
  historicalCAGR        Float?
  projectedCAGRMin      Float?
  projectedCAGRMax      Float?
  rentalYieldMin        Float?
  rentalYieldMax        Float?
  bestHorizonYearsMin   Int?
  bestHorizonYearsMax   Int?
  riskLevel             RiskLevel
  
  // Forecast
  forecast3yrMin        Float?   // % appreciation
  forecast3yrMax        Float?
  forecast5yrMin        Float?
  forecast5yrMax        Float?
  forecast10yrMin       Float?
  forecast10yrMax       Float?
  priceIndex2031        Int?     // e.g. 210 (2026=100)
  
  // Intelligence score components (auto-computed)
  overallScore          Int?
  infraScore            Int?
  approvalScore         Int?
  demandScore           Int?
  appreciationScore     Int?
  sentiment             Sentiment?  // BULLISH, NEUTRAL, CAUTIOUS
  
  // Content
  keyDrivers            String[]   // Top 3 appreciation drivers
  keyRisks              String[]   // Top 2 risks
  bestFor               String[]   // Persona types
  historicalAnalog      String?    // "Similar to Kompally in 2009"
  adminNote             String?    // Admin editorial commentary
  
  // Sub-areas / micro-localities within this corridor
  subAreas              String[]   // ["Tukkuguda", "Maheshwaram", "Mucherla"]
  
  // Relationships
  infraProjects         InfraProject[]
  appreciationHistory   AppreciationHistory[]
  demandTrends          DemandTrend[]
  approvalRecords       ApprovalRecord[]
  intelligence          CorridorIntelligence?
  
  isPublished           Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum Direction {
  WEST
  NORTHWEST
  NORTH
  NORTHEAST
  EAST
  SOUTHEAST
  SOUTH
  SOUTHWEST
}

enum HeatRating {
  FIRE              // 🔥🔥 Actively moving, entry window closing
  VERY_HOT          // 🔥 Strong momentum, still good entry
  HOT               // Strong fundamentals, pre-trigger
  WARM              // Identified but catalysts still pending
  EMERGING          // Early signals, confirmed infrastructure
  EARLY             // Patient capital, 7-10 year horizon
}

enum InvCycle {
  ACT_NOW           // 2026-2028 pre-construction window
  MID_CYCLE         // Construction-active, still upside
  WATCH_AND_BUY     // 2028-2031
  PATIENT_CAPITAL   // 2031-2035
}

enum RRRAlignment {
  NORTH_CORRIDOR    // On/near RRR North (Sangareddy→Bhongir)
  SOUTH_CORRIDOR    // On/near RRR South (Sangareddy→Kandukur)
  BOTH
  NONE
}

enum Sentiment {
  BULLISH
  NEUTRAL
  CAUTIOUS
}

model Broadcast {
  id              String          @id @default(cuid())
  name            String          // Admin-given name e.g. "Diwali Offer - NRI Investors"
  channel         BroadcastChannel // WHATSAPP or EMAIL or BOTH
  templateId      String?
  emailSubject    String?
  emailBody       String?
  whatsappMessage String?
  groupType       GroupType       // How the recipients were selected
  groupFilters    Json            // Snapshot of filters used
  recipientCount  Int             @default(0)
  status          BroadcastStatus @default(DRAFT)
  scheduledAt     DateTime?       // null = send immediately
  sentAt          DateTime?
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  recipients      BroadcastRecipient[]
}

model BroadcastRecipient {
  id              String          @id @default(cuid())
  broadcastId     String
  broadcast       Broadcast       @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  leadId          String
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  whatsappStatus  WAStatus?
  emailStatus     EmailStatus?
  whatsappSentAt  DateTime?
  emailSentAt     DateTime?
  emailMessageId  String?
  whatsappMessageId String?
  errorMessage    String?
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  subject     String
  body        String   // HTML email body with {{merge_tags}}
  isActive    Boolean  @default(true)
  sentCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum BroadcastChannel {
  WHATSAPP
  EMAIL
  BOTH
}

enum BroadcastStatus {
  DRAFT
  SENDING
  SENT
  FAILED
  SCHEDULED
}

enum GroupType {
  PERSONA           // All leads of a specific buyer persona
  LEAD_STATUS       // All leads at a specific CRM status
  PIPELINE_STAGE    // All leads at a specific pipeline stage
  SCORE_GRADE       // All leads with a specific score grade (A/B/C/D)
  CORRIDOR_INTEREST // All leads who searched a specific corridor
  BUDGET_RANGE      // All leads within a budget range
  MANUAL_PICK       // Admin hand-picked individual leads
  ALL_LEADS         // Everyone in the database
}

enum EmailStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  FAILED
  BOUNCED
}

// ── GOVERNMENT INFRASTRUCTURE PROJECTS ──────────────────────────────────────

model InfraProject {
  id                    String         @id @default(cuid())
  name                  String
  shortName             String
  category              InfraCategory
  subCategory           String?
  description           String
  status                InfraStatus
  completionPct         Int            @default(0)
  estimatedCompletion   String?        // "FY 2026-27", "Q3 2029"
  totalLengthKm         Float?
  totalInvestmentCr     Float?
  fundingModel          String?        // "HAM", "EPC", "PPP", "JICA"
  expectedJobs          Int?
  
  // Official reference data
  sourceGO              String?        // "G.O.Ms.No.68 MA&UD dt.12-03-2025"
  sourceTender          String?        // "NHAI Tender Jan 16, 2026"
  sourceAuthority       String?        // "NHAI", "HMRL", "TSIIC"
  sourceUrl             String?
  lastVerifiedDate      DateTime?
  lastVerifiedSource    String?
  
  // Geography
  routeDescription      String?        // "Sangareddy → Toopran → Bhongir"
  affectedCorridorSlugs String[]       // references CorridorProfile.slug
  impactRadiusKm        Float          @default(10)
  latitude              Float?
  longitude             Float?
  coordinates           Json?          // Array of [lat,lng] for route polylines
  
  // Impact
  reImpactScore         Int            @default(0)  // 1-10
  reImpactNarrative     String?        // "Expected 25-40% appreciation in 5km radius"
  historicalAnalog      String?        // "Similar to ORR effect on Kompally (2009)"
  
  isPublished           Boolean        @default(true)
  milestones            InfraMilestone[]
  corridors             CorridorProfile[]
  
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  affectedCorridors     String[]       // keeping for backward compatibility
  impactRadius          Float          @default(10) // keeping for backward compatibility
}

model InfraMilestone {
  id            String       @id @default(cuid())
  projectId     String
  project       InfraProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String       // "Land Acquisition 94% Complete"
  date          DateTime?
  status        MilestoneStatus @default(UPCOMING)
  description   String?
  sourceUrl     String?
}

enum InfraCategory {
  ROAD_HIGHWAY        // RRR, ORR, NH expansions, flyovers
  METRO_RAIL          // Metro extensions, new corridors
  INDUSTRIAL_ZONE     // TSIIC industrial parks, SEZs
  PHARMA_BIOTECH      // Pharma City, Genome Valley
  LOGISTICS_PARK      // Warehousing hubs, dry ports, freight terminals
  AIRPORT_AVIATION    // RGIA expansion, cargo terminals, aerospace SEZ
  GOVT_APPROVAL       // HMDA layout approvals, DTCP approvals
  TOWNSHIP            // Satellite townships, master plan zones
  IT_TECH_PARK        // IT corridors, hardware parks
  UTILITY             // Water supply, power grid, sewage
}

enum InfraStatus {
  ANNOUNCED           // Government announcement only
  APPROVED            // Government order issued
  LAND_ACQUISITION    // Land acquisition in progress
  UNDER_CONSTRUCTION  // Active construction
  PARTIALLY_COMPLETE  // Some phases done
  COMPLETE            // Fully operational
  DELAYED             // Official delay announced
  CANCELLED           // Cancelled or stalled
}

enum MilestoneStatus {
  COMPLETED
  IN_PROGRESS
  UPCOMING
}

// ── AREA APPRECIATION HISTORY ─────────────────────────────────────────────────

model AppreciationHistory {
  id                  String   @id @default(cuid())
  corridor            String   // Must match CorridorProfile.slug or shortName
  year                Int
  quarter             Int?     // 1-4, null = annual
  pricePerSqFt        Float    // Average price per sq ft in ₹
  pricePerSqYd        Float?   // For plot markets
  yoyChange           Float    // Year-over-year % change
  qoqChange           Float?   // Quarter-over-quarter % change
  sampleSize          Int?     // Number of transactions this is based on
  source              String?  // "RERA Data", "Market Research", "Admin Estimate"
  notes               String?
  createdAt           DateTime @default(now())
  
  corridorProfileSlug String?
  corridorProfile     CorridorProfile? @relation(fields: [corridorProfileSlug], references: [slug])
}

// ── DEMAND TREND DATA ─────────────────────────────────────────────────────────

model DemandTrend {
  id                  String   @id @default(cuid())
  corridor            String
  month               Int      // 1-12
  year                Int
  searchVolume        Int?     // Portal search count for this corridor
  inquiryCount        Int?     // Leads who expressed interest
  siteVisits          Int?     // Site visits arranged
  newListings         Int?     // New projects listed
  inventoryUnits      Int?     // Total units available
  soldUnits           Int?     // Units sold/booked this month
  absorptionRate      Float?   // % of inventory absorbed
  medianDaysOnMkt     Int?     // Median days project stays on market
  createdAt           DateTime @default(now())
  
  corridorProfileSlug String?
  corridorProfile     CorridorProfile? @relation(fields: [corridorProfileSlug], references: [slug])

  @@unique([corridor, month, year])
}

// ── HMDA / DTCP APPROVAL TRACKER ─────────────────────────────────────────────

model ApprovalRecord {
  id                  String         @id @default(cuid())
  projectName         String
  developerName       String?
  approvalType        ApprovalType
  authority           ApprovalAuth   // HMDA, DTCP, GHMC, RERA
  approvalNumber      String?        // LP number, RERA number, GO number
  approvalDate        DateTime?
  corridor            String?
  areaAcres           Float?
  surveyNumbers       String[]
  status              ApprovalStatus @default(APPROVED)
  reraNumber          String?
  reraUrl             String?
  notes               String?
  isPublished         Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  
  corridorProfileSlug String?
  corridorProfile     CorridorProfile? @relation(fields: [corridorProfileSlug], references: [slug])
}

enum ApprovalType {
  LAYOUT_APPROVAL
  BUILDING_PERMISSION
  RERA_REGISTRATION
  ENVIRONMENTAL_CLEARANCE
  SEZ_APPROVAL
  INDUSTRIAL_ALLOTMENT
  TOWNSHIP_APPROVAL
}

enum ApprovalAuth {
  HMDA
  DTCP
  GHMC
  RERA_TELANGANA
  TSIIC
  NHAI
  MOEF     // Ministry of Environment
  GOT      // Government of Telangana
}

enum ApprovalStatus {
  APPROVED
  PENDING
  REVOKED
  EXPIRED
}

// ── CORRIDOR INTELLIGENCE SCORE ───────────────────────────────────────────────

model CorridorIntelligence {
  id                   String   @id @default(cuid())
  corridor             String   @unique
  overallScore         Int      // 1-100 computed
  infraScore           Int      // 1-25: proximity to govt infra projects
  approvalScore        Int      // 1-25: HMDA/DTCP/RERA approvals in zone
  demandScore          Int      // 1-25: search + inquiry trends
  appreciationScore    Int      // 1-25: historical price growth
  investorSentiment    String   // "BULLISH" | "NEUTRAL" | "CAUTIOUS"
  adminNote            String?  // Admin commentary shown to clients
  keyDrivers           String[] // Top 3 reasons for the score
  keyRisks             String[] // Top 2 risks
  bestFor              String[] // Persona types this corridor suits
  lastComputedAt       DateTime @default(now())
  
  corridorProfileSlug String?          @unique
  corridorProfile     CorridorProfile? @relation(fields: [corridorProfileSlug], references: [slug])
}

// ── LEGAL RISK DATABASE ────────────────────────────────────────────────────

model LegalRisk {
  id            String        @id @default(cuid())
  title         String        // "Section 22-A RRR Acquisition Trap"
  severity      RiskSeverity  // RED, YELLOW, ORANGE, GREEN
  category      LegalCategory
  description   String        // Full explanation
  affectedZones String[]      // Which corridors/areas this applies to
  checkUrl      String?       // "bhubharati.telangana.gov.in"
  checkMethod   String?       // How to verify
  govReference  String?       // "Telangana Bhu Bharati Act, 2025"
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
}

enum RiskSeverity {
  RED
  ORANGE
  YELLOW
  GREEN
}

enum LegalCategory {
  LAND_RECORDS      // Bhu Bharati, Section 22-A
  APPROVALS         // HMDA, DTCP, layout LP number
  RERA              // RERA registration, QPR compliance
  ENCUMBRANCE       // EC, mortgage, lien
  RESTRICTIONS      // GO 111, Lake FTL, Air Funnel
  STAMP_DUTY        // Registration costs, circle rates
  AGRICULTURAL      // NALA conversion
  FRAUD_PATTERN     // Common scam types
}

// ── MARKET PULSE DATA ─────────────────────────────────────────────────────

model MarketPulse {
  id                    String   @id @default(cuid())
  period                String   // "FY2025-26", "Q1 2026"
  totalRegistrations    Int?     // 51,089
  totalValueCr          Float?   // 34,420
  yoyGrowthPct          Float?   // 40.0
  avgAskingPriceSqFt    Float?   // 9,430
  avgGovtCircleRateSqFt Float?   // 3,654
  gccNewCount           Int?     // 40 (new GCCs added)
  gccTotalPct           Float?   // 20.0 (% of India's GCCs)
  officeAbsorptionMSqFt Float?
  gccShareOfOffice      Float?   // 50.0 %
  source                String?
  reportDate            DateTime
  createdAt             DateTime @default(now())
}



